# База данных (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/task_switcher

# Better-auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=task-switcher-super-secret-key-2024-large-extra-more-length
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Pusher (https://pusher.com — бесплатный тариф Sandbox)
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=eu

# Публичные переменные Pusher (видны клиенту)
NEXT_PUBLIC_PUSHER_KEY=your_pusher_key
NEXT_PUBLIC_PUSHER_CLUSTER=eu
